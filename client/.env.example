# ============================================
# LastKey Digital Legacy - Client Environment
# ============================================

# Required: API base URL for backend
VITE_API_BASE_URL=http://localhost:5000/api

# Optional: WebSocket URL (defaults to API base URL)
VITE_WS_URL=ws://localhost:5000

# Optional: Environment (development, production, test)
VITE_NODE_ENV=development

# Optional: Analytics/Monitoring (optional)
# VITE_SENTRY_DSN=your-sentry-dsn
# VITE_GA_TRACKING_ID=your-google-analytics-id
