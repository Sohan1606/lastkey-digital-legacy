# ============================================
# LastKey Digital Legacy - Client Environment
# ============================================

# Required: API base URL for backend
VITE_API_BASE_URL=http://localhost:5000/api

# Optional: WebSocket URL (defaults to API base URL)
VITE_WS_URL=ws://localhost:5000

# Optional: Environment (development, production, test)
VITE_NODE_ENV=development

# ============================================
# Analytics & Monitoring (Optional)
# ============================================
# Sentry for error tracking and performance monitoring
# Get your DSN from https://sentry.io/
VITE_SENTRY_DSN=your-sentry-dsn

# Google Analytics for user behavior tracking
# Get your tracking ID from Google Analytics
VITE_GA_TRACKING_ID=your-google-analytics-id

# PostHog for product analytics and feature flags
# Get your API key from https://app.posthog.com/project/settings
VITE_POSTHOG_API_KEY=your-posthog-api-key
VITE_POSTHOG_HOST=https://app.posthog.com

# ============================================
# Feature Flags (Optional)
# ============================================
# Enable/disable specific features
VITE_ENABLE_AI_FEATURES=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false

# ============================================
# Development Settings (Optional)
# ============================================
# Enable hot module replacement in development
VITE_HMR=true

# Enable source maps for debugging
VITE_SOURCE_MAP=true

# API timeout in milliseconds
VITE_API_TIMEOUT=30000
