# ============================================
# LastKey Digital Legacy - Root Environment Template
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ============================================
# Client Configuration (Vite)
# ============================================
VITE_API_BASE_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/lastkey

# Security - Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# Email Configuration (Required in production)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=LastKey <noreply@lastkey.io>

# ============================================
# Optional Integrations
# ============================================
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (for AI features)
OPENAI_API_KEY=sk-your-openai-key

# ============================================
# Application URLs
# ============================================
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000
