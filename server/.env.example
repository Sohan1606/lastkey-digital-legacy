PORT=5000
MONGO_URI=mongodb://localhost:27017/lastkey
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=90d

# Vault encryption - REQUIRED in production
ASSET_ENCRYPTION_KEY=your-32-character-asset-encryption-key

# Redis (required for production queue - fallback to cron if not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe (optional - disables payments if not set)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_GUARDIAN_PRICE_ID=price_...
STRIPE_LEGACY_PRO_PRICE_ID=price_...

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your-app-password

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development

# WhatsApp/Telegram (optional)
WHATSAPP_API_KEY=your_whatsapp_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Estate Administrator (for emergency notifications)
ESTATE_ADMIN_EMAIL=admin@lastkey.com
