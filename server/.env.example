# ============================================
# LastKey Digital Legacy - Server Environment
# ============================================

# Required: Node environment (development, production, test)
NODE_ENV=development

# Required: Server port
PORT=5000

# Required: MongoDB connection string
# Format: mongodb://username:password@host:port/database
MONGO_URI=mongodb://localhost:27017/lastkey

# Required: JWT secret for authentication (min 32 chars in production)
# Generate a secure random string: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Required in production: Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ============================================
# FREE_MODE: College Project Configuration
# ============================================
# Set to 'true' for free local development (no paid services required)
FREE_MODE=true
EMAIL_MODE=console

# Feature flags (disable paid features in FREE_MODE)
FEATURE_AI=false
FEATURE_PAYMENTS=false

# ============================================
# Email Configuration (Required in production, optional in FREE_MODE)
# ============================================
# When EMAIL_MODE=console or FREE_MODE=true, emails print to terminal
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=LastKey <noreply@lastkey.io>

# ============================================
# Stripe Configuration (Optional - disable in FREE_MODE)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# Security & Encryption
# ============================================
# Legacy encryption key for migration (remove after migration complete)
LEGACY_ENCRYPTION_KEY=your-legacy-encryption-key

# WebAuthn/Passkey configuration
WEBAUTHN_RP_ID=localhost

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================================
# File Upload
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
